# AI Agent Team System - Environment Variables

# === LLM Provider Configuration ===
# Default provider: gemini, openai, ollama
LLM_PROVIDER=gemini

# Google Gemini API (default)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API (optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama Local (optional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# === Project Defaults ===
# Default directory for new projects
DEFAULT_PROJECT_DIR=./projects

# === Dashboard ===
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8420

# === Git ===
GIT_AUTO_COMMIT=true
GIT_AUTO_PUSH=false
GIT_DEFAULT_BRANCH=main

# === GitHub CLI ===
# Make sure `gh` CLI is installed and authenticated: gh auth login
GITHUB_AUTO_CREATE_REPO=false
GITHUB_DEFAULT_VISIBILITY=private

# === Autonomous Level ===
# safe = always ask before file changes
# semi_auto = work freely, user reviews at end
# full_auto = work + commit + deploy without asking
AUTONOMOUS_LEVEL=semi_auto

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///data/agent_team.db
